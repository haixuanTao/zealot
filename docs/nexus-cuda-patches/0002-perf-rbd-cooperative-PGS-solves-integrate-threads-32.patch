+        let delta = shared_delta.read(0);
+        if delta != 0.0 {
+            let mut i = lane;
+            while i < ndofs {
+                let v_idx = v_base + i as usize;
+                let cur = dof_state.read(v_idx);
+                let col = joint_constraint_columns
+                    .read(col_base + (s as usize) * dofs_stride + i as usize);
+                dof_state.write(v_idx, cur - delta * col);
